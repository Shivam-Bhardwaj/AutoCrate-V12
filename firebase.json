{
  "hosting": {
    "public": "web/static",
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "/docs/**",
        "destination": "/docs/index.html"
      },
      {
        "source": "**",
        "function": "app"
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "functions": {
    "source": "web",
    "runtime": "python311",
    "ignore": [
      "venv",
      ".git",
      "**/__pycache__/**",
      "*.pyc"
    ]
  }
}