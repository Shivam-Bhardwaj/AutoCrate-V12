# Environment Variables for AutoCrate Web

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=your-secret-key-here

# Authentication
# Default password is "autocrate2024" - CHANGE THIS IN PRODUCTION
AUTH_PASSWORD_HASH=your-password-hash-here

# Firebase Configuration (optional, for enhanced features)
FIREBASE_PROJECT_ID=autocrate-web
FIREBASE_PRIVATE_KEY_ID=your-key-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_CLIENT_ID=your-client-id

# Application Settings
MAX_UPLOAD_SIZE=10485760
SESSION_LIFETIME_HOURS=24
ENABLE_DEBUG_MODE=false